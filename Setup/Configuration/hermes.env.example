# Store the real file as Setup/Configuration/hermes.env.
# Ansible copies it to /var/lib/hermes/env on Failsafe with mode 0600.

# Model provider credentials. Keep only the providers you actually use.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Configure at least one messaging transport and a user allowlist.
# For a private single-user setup, prefer explicit allowlists over
# GATEWAY_ALLOW_ALL_USERS=true.

# Telegram example:
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=

# Discord example:
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=

# Unsafe except for short private testing windows:
# GATEWAY_ALLOW_ALL_USERS=false
